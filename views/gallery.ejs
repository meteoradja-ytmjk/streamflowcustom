          <button onclick="navigateToThumbnailFolder(null)" class="hover:text-white transition-colors text-xs">All Thumbnails</button>
          <i class="ti ti-chevron-right text-[10px] text-gray-500"></i>
          <span class="text-white text-xs">${escapeHtml(currentFolderObj.name)}</span>
        `;
      } else {
        breadcrumb.innerHTML = `
          <i class="ti ti-photo text-primary"></i>
          <span class="text-xs">All Thumbnails</span>
        `;
      }
    }

    // Render Folders List (LEFT COLUMN)
    if (foldersContainer) {
      if (allFolders.length === 0) {
        foldersContainer.innerHTML = `
          <div class="text-center py-8 text-gray-500">
            <i class="ti ti-folder-off text-3xl mb-2"></i>
            <p class="text-[11px]">No folders yet</p>
          </div>
        `;
      } else {
        let foldersHtml = '';
        allFolders.forEach(folder => {
          const isActive = currentThumbnailFolderId === folder.id;
          const name = escapeHtml(folder.name || '');
          foldersHtml += `
            <div class="group relative bg-dark-700 ${isActive ? 'border-2 border-primary' : 'border border-gray-600'} rounded-lg p-3 hover:bg-dark-600 transition-all cursor-pointer"
              onclick="navigateToThumbnailFolder('${escapeHtml(folder.id)}')">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg ${isActive ? 'bg-primary/20 text-primary' : 'bg-gray-700 text-gray-400'} flex items-center justify-center shrink-0">
                  <i class="ti ti-folder text-lg"></i>
                </div>
                <div class="flex-1 min-w-0">
                  <h5 class="text-xs font-semibold text-white truncate">${name}</h5>
                  <p class="text-[10px] text-gray-400">${folder.item_count || 0} items</p>
                </div>
                <div class="flex flex-col gap-0.5 opacity-0 group-hover:opacity-100 transition-opacity">
                  <button class="text-gray-400 hover:text-white p-1 rounded" onclick="event.stopPropagation(); showRenameFolderDialog('${escapeHtml(folder.id)}', '${name}')" title="Rename">
                    <i class="ti ti-pencil text-xs"></i>
                  </button>
                  <button class="text-gray-400 hover:text-red-400 p-1 rounded" onclick="event.stopPropagation(); showDeleteFolderDialog('${escapeHtml(folder.id)}', '${name}')" title="Delete">
                    <i class="ti ti-trash text-xs"></i>
                  </button>
                </div>
              </div>
            </div>
          `;
        });
        
        // Add "All Thumbnails" option at top
        foldersHtml = `
          <div class="group relative bg-dark-700 ${!currentThumbnailFolderId ? 'border-2 border-primary' : 'border border-gray-600'} rounded-lg p-3 hover:bg-dark-600 transition-all cursor-pointer mb-2"
            onclick="navigateToThumbnailFolder(null)">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-lg ${!currentThumbnailFolderId ? 'bg-primary/20 text-primary' : 'bg-gray-700 text-gray-400'} flex items-center justify-center shrink-0">
                <i class="ti ti-photo text-lg"></i>
              </div>
              <div class="flex-1 min-w-0">
                <h5 class="text-xs font-semibold text-white">All Thumbnails</h5>
                <p class="text-[10px] text-gray-400">${allImages.filter(img => !img.folder_id).length} items</p>
              </div>
            </div>
          </div>
        ` + foldersHtml;
        
        foldersContainer.innerHTML = foldersHtml;
      }
    }

    // Render Images Grid (MIDDLE COLUMN)
    if (totalImages === 0) {
      imagesContainer.innerHTML = `
        <div class="col-span-full text-center py-10 bg-dark-900/40 rounded-xl border border-dashed border-gray-700">
          <i class="ti ti-photo-off text-3xl text-gray-500 mb-2"></i>
          <p class="text-xs text-gray-400 font-medium">${currentFolderObj ? 'Folder ini kosong' : 'Belum ada gambar'}</p>
          <p class="text-[11px] text-gray-500 mb-3">Upload gambar untuk memulai</p>
          <button onclick="openThumbnailUploadModal()" class="px-4 py-2 bg-primary text-white text-xs font-semibold rounded-lg hover:bg-rose-600 transition-colors">
            Upload Thumbnail
          </button>
        </div>
      `;
      return;
    }

    let imagesHtml = '';
    folderImages.forEach(img => {
      const isSelected = activeStudioImage && activeStudioImage.id === img.id;
      const title = escapeHtml(img.title || '');
      const thumb = escapeHtml(img.thumbnail_path || img.filepath || '');
      imagesHtml += `
        <div class="thumbnail-studio-card group relative bg-dark-900 rounded-xl overflow-hidden border ${isSelected ? 'border-primary ring-2 ring-primary/30' : 'border-gray-700 hover:border-gray-500'} transition-all cursor-pointer shadow-sm"
          onclick="selectStudioImage('${escapeHtml(img.id)}')" data-id="${escapeHtml(img.id)}">
          <div class="aspect-video relative overflow-hidden bg-black/60">
            <img src="${thumb}" alt="${title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
            ${isSelected ? `
            <div class="absolute top-2 right-2 bg-primary text-white rounded-full p-1 shadow-md">
              <i class="ti ti-check text-xs"></i>
            </div>` : ''}
          </div>
          <div class="p-2.5">
            <h5 class="text-xs font-medium text-white truncate mb-0.5">${title}</h5>
            <div class="flex items-center justify-between text-[10px] text-gray-400">
              <span>${formatFileSize(img.file_size || 0)}</span>
              <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                <button class="text-gray-400 hover:text-white p-0.5 rounded" onclick="event.stopPropagation(); showRenameDialog('${escapeHtml(img.id)}', '${title}')" title="Rename">
                  <i class="ti ti-pencil"></i>
                </button>
                <button class="text-gray-400 hover:text-red-400 p-0.5 rounded" onclick="event.stopPropagation(); showDeleteDialog('${escapeHtml(img.id)}', '${title}')" title="Delete">
                  <i class="ti ti-trash"></i>
                </button>
              </div>
            </div>
          </div>
        </div>
      `;
    });

    imagesContainer.innerHTML = imagesHtml;

    // Auto select first image if none selected
    if (!activeStudioImage && folderImages.length > 0) {
      selectStudioImage(folderImages[0].id);
    }
  }

  window.selectStudioImage = async function(imageId) {
    const images = (galleryVideosState || []).filter(isImageMediaItem);
    const img = images.find(i => i.id === imageId);
    if (!img) return;

    activeStudioImage = img;

    // Update active highlight class on grid cards
    document.querySelectorAll('.thumbnail-studio-card').forEach(card => {
      const isThis = card.dataset.id === imageId;
      card.className = `thumbnail-studio-card group relative bg-dark-900 rounded-xl overflow-hidden border ${isThis ? 'border-primary ring-2 ring-primary/30' : 'border-gray-700 hover:border-gray-500'} transition-all cursor-pointer shadow-sm`;
    });

    // Toggle Studio States
    document.getElementById('studioEmptyState').classList.add('hidden');
    document.getElementById('studioActiveState').classList.remove('hidden');

    // Update preview details
    document.getElementById('studioImgPreview').src = img.filepath;
    document.getElementById('studioImgTitle').textContent = img.title;
    document.getElementById('studioImgSize').textContent = formatFileSize(img.file_size || 0);
    document.getElementById('studioImgDim').textContent = img.resolution || '-- x --';

    // Reset YouTube Studio controls
    document.getElementById('studioYtLoading').classList.remove('hidden');
    document.getElementById('studioYtNoChannels').classList.add('hidden');
    document.getElementById('studioYtControls').classList.add('hidden');

    setStudioMode('stream');

    try {
      // 1. Load YouTube channels
      const channelsRes = await fetch('/api/youtube/channels');
      const channelsData = await channelsRes.json();

      if (!channelsData.success || !channelsData.channels || channelsData.channels.length === 0) {
        document.getElementById('studioYtLoading').classList.add('hidden');
        document.getElementById('studioYtNoChannels').classList.remove('hidden');
        return;
      }

      studioChannels = channelsData.channels;
      const channelSelect = document.getElementById('studioYtChannelSelect');
      channelSelect.innerHTML = studioChannels.map(c => `
        <option value="${c.id}">${c.channel_name} (${c.subscriber_count} subs)</option>
      `).join('');

      // 2. Load stream configurations
      const streamsRes = await fetch('/api/streams');
      const streamsData = await streamsRes.json();

      if (streamsData.success && streamsData.streams) {
        studioStreams = streamsData.streams.filter(s => s.is_youtube_api || s.platform === 'YouTube' || s.platform?.toLowerCase?.() === 'youtube');
      } else {
        studioStreams = [];
      }

      const streamSelect = document.getElementById('studioStreamSelect');
      if (studioStreams.length > 0) {
        streamSelect.innerHTML = studioStreams.map(s => `
          <option value="${s.id}">${s.title}</option>
        `).join('');
      } else {
        streamSelect.innerHTML = '<option value="">-- Tidak ada stream config YouTube --</option>';
      }

      document.getElementById('studioYtLoading').classList.add('hidden');
      document.getElementById('studioYtControls').classList.remove('hidden');

      channelSelect.onchange = () => {
        if (activeStudioMode === 'broadcast') {
          refreshStudioBroadcasts();
        }
      };

    } catch (e) {
      console.error('Error loading studio data:', e);
      document.getElementById('studioYtLoading').classList.add('hidden');
      document.getElementById('studioYtNoChannels').classList.remove('hidden');
    }
  };

  window.setStudioMode = function(mode) {
    activeStudioMode = mode;
    const btnStream = document.getElementById('btnStudioModeStream');
    const btnBroadcast = document.getElementById('btnStudioModeBroadcast');
    const containerStream = document.getElementById('studioTargetStreamContainer');
    const containerBroadcast = document.getElementById('studioTargetBroadcastContainer');

    if (mode === 'stream') {
      btnStream.className = 'flex-1 py-1.5 px-3 rounded-lg border border-primary bg-primary/10 text-primary text-xs font-medium transition-all';
      btnBroadcast.className = 'flex-1 py-1.5 px-3 rounded-lg border border-gray-600 bg-dark-700 text-gray-400 hover:text-white text-xs font-medium transition-all';
      containerStream.classList.remove('hidden');
      containerBroadcast.classList.add('hidden');
    } else {
      btnBroadcast.className = 'flex-1 py-1.5 px-3 rounded-lg border border-primary bg-primary/10 text-primary text-xs font-medium transition-all';
      btnStream.className = 'flex-1 py-1.5 px-3 rounded-lg border border-gray-600 bg-dark-700 text-gray-400 hover:text-white text-xs font-medium transition-all';
      containerBroadcast.classList.remove('hidden');
      containerStream.classList.add('hidden');
      refreshStudioBroadcasts();
    }
  };

  window.refreshStudioBroadcasts = async function() {
    const channelSelect = document.getElementById('studioYtChannelSelect');
    if (!channelSelect || !channelSelect.value) return;

    const broadcastSelect = document.getElementById('studioBroadcastSelect');
    broadcastSelect.innerHTML = '<option value="">Memuat siaran broadcast...</option>';
    broadcastSelect.disabled = true;

    try {
      const res = await fetch(`/api/youtube/broadcasts/${channelSelect.value}`);
      const data = await res.json();

      if (data.success && data.broadcasts && data.broadcasts.length > 0) {
        broadcastSelect.innerHTML = data.broadcasts.map(b => `
          <option value="${b.id}">${b.snippet.title} (${b.status.lifeCycleStatus || b.status.privacyStatus})</option>
        `).join('');
        broadcastSelect.disabled = false;
      } else {
        broadcastSelect.innerHTML = '<option value="">-- Tidak ada broadcast aktif --</option>';
        broadcastSelect.disabled = true;
      }
    } catch (e) {
      console.error(e);
      broadcastSelect.innerHTML = '<option value="">Gagal memuat broadcast</option>';
      broadcastSelect.disabled = true;
    }
  };

  window.applyStudioThumbnail = async function() {
    if (!activeStudioImage) return;

    const targetType = activeStudioMode;
    const channelId = document.getElementById('studioYtChannelSelect').value;

    let targetId = '';
    if (targetType === 'stream') {
      targetId = document.getElementById('studioStreamSelect').value;
      if (!targetId) {
        showToast('error', 'Pilih target konfigurasi stream.');
        return;
      }
    } else {
      targetId = document.getElementById('studioBroadcastSelect').value;
      if (!targetId) {
        showToast('error', 'Pilih target broadcast YouTube aktif.');
        return;
      }
    }

    const btn = document.getElementById('btnStudioApply');
    const originalText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div> Memasang...';

    try {
      const csrfInput = document.querySelector('input[name="_csrf"]');
      const response = await fetch('/api/gallery/apply-thumbnail', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfInput ? csrfInput.value : ''
        },
        body: JSON.stringify({
          videoId: activeStudioImage.id,
          targetType,
          targetId,
          channelId
        })
      });
      const data = await response.json();
      btn.disabled = false;
      btn.innerHTML = originalText;

      if (data.success) {
        showToast('success', data.message || 'Thumbnail berhasil dipasang!');
        await window.refreshGalleryData?.();
      } else {
        showToast('error', data.error || 'Gagal memasang thumbnail');
      }
    } catch (error) {
      btn.disabled = false;
      btn.innerHTML = originalText;
      console.error(error);
      showToast('error', 'Terjadi kesalahan saat memasang thumbnail.');
    }
  };
</script>

