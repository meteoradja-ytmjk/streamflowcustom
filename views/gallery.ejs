        <i class="ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
      </div>
    </div>
    
    <!-- Filters and Actions Row - Single Line with Same Height -->
    <div class="flex items-center justify-between gap-1.5 sm:gap-2">
      <!-- Left: Filters -->
      <div class="flex items-center gap-1.5 sm:gap-2">
        <select id="typeFilter" class="bg-dark-700 border border-gray-600 text-white pl-2 pr-5 h-10 focus:outline-none focus:ring-2 focus:ring-primary text-xs w-[96px] sm:w-[100px] sm:px-3 sm:text-sm">
          <option value="all">All Media</option>
          <option value="video">Video</option>
          <option value="audio">Audio</option>
          <option value="image">Image/Thumbnail</option>
        </select>
        <select id="sortSelect" class="bg-dark-700 border border-gray-600 text-white pl-2 pr-5 h-10 focus:outline-none focus:ring-2 focus:ring-primary text-xs w-[84px] sm:w-[90px] sm:px-3 sm:text-sm">
          <option value="newest">Newest</option>
          <option value="oldest">Oldest</option>
          <option value="name">Name</option>
          <option value="size">Size</option>
        </select>
      </div>
      
      <!-- Right: Actions -->
      <div class="flex items-center gap-1.5 sm:gap-2">
        <div class="flex bg-dark-700 border border-gray-600 rounded-lg overflow-hidden h-9">
          <button id="gridViewBtn" onclick="switchView('grid')" class="px-3 h-full bg-primary text-white transition-colors flex items-center justify-center" title="Grid view">
            <i class="ti ti-layout-grid"></i>
          </button>
          <button id="listViewBtn" onclick="switchView('list')" class="px-3 h-full text-gray-400 hover:text-white hover:bg-dark-600 transition-colors flex items-center justify-center" title="List view">
            <i class="ti ti-list"></i>
          </button>
        </div>
        <% if (!currentFolder) { %>
        <button onclick="openCreateFolderDialog()" class="flex items-center justify-center w-9 h-9 bg-dark-700 border border-gray-600 hover:bg-dark-600 text-white rounded-lg transition-colors" title="Create folder">
          <i class="ti ti-folder-plus"></i>
        </button>
        <% } %>
      </div>
    </div>
  </div>

  <div id="galleryContent" class="p-4">
    <!-- Selection Action Bar -->
    <div id="selectionBar" class="hidden mb-4 p-3 bg-dark-700 rounded-lg border border-gray-600 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="text-sm font-medium text-white">
          <span id="selectedCount">0</span> items
        </span>
        <button onclick="clearSelection()" class="text-xs text-gray-400 hover:text-white transition-colors">Clear</button>
      </div>
      <div class="flex items-center gap-2">
        <% if (currentFolder || folders && folders.length > 0) { %>
        <button onclick="showMoveSelectedDialog()" class="flex items-center gap-2 bg-dark-600 hover:bg-dark-500 text-white px-4 py-2 rounded-lg transition-colors text-sm">
          <i class="ti ti-folder-symlink"></i>
          <span>Move</span>
        </button>
        <% } %>
        <button onclick="showDeleteSelectedDialog()" class="flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg transition-colors text-sm">
          <i class="ti ti-trash"></i>
          <span>Delete</span>
        </button>
      </div>
    </div>

    <% if (hasGalleryItems) { %>
    <div id="gridView" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
      <% if (hasRootFolders) { %>
      <% folders.forEach(function(folder) { %>
      <a href="/gallery?folder=<%= folder.id %>" class="gallery-grid-item folder-drop-target group bg-dark-700 rounded-lg border border-gray-700 hover:border-gray-600 hover:bg-dark-600 transition-all p-4 flex flex-col justify-between min-h-[172px]"
        data-folder-id="<%= folder.id %>" data-kind="folder" data-type="folder" data-title="<%= folder.name %>" data-date="<%= folder.updated_at || folder.created_at %>" data-size="0">
