document.getElementById('submit-local-import')?.addEventListener('click', async function() {
  const pathInput = document.getElementById('local-import-path').value.trim();
  
  // If user typed a path manually but it's not in the list, add it
  if (pathInput && !selectedLocalFiles.some(f => f.path === pathInput)) {
    selectedLocalFiles.push({
      path: pathInput,
      name: pathInput.split(/[\\\/]/).pop()
    });
  }

  if (selectedLocalFiles.length === 0) {
    showToast('error', 'Silakan pilih atau masukkan path file lokal.');
    return;
  }

  const btn = this;
  const originalHtml = btn.innerHTML;
  btn.disabled = true;
  
  let successCount = 0;
  let failCount = 0;
  const titleInput = document.getElementById('local-import-title').value.trim();

  const filesToProcess = [...selectedLocalFiles];
  for (let i = 0; i < filesToProcess.length; i++) {
    const file = filesToProcess[i];
    btn.innerHTML = `<i class="ti ti-loader animate-spin mr-2"></i>(${i+1}/${filesToProcess.length}) ${file.name.substring(0, 10)}...`;
    
    try {
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 120000); // 2 minute timeout

      const response = await fetch('/api/videos/import-local', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('input[name="_csrf"]').value
        },
        body: JSON.stringify({
          localPath: file.path,
          title: filesToProcess.length === 1 ? titleInput : '',
          folderId: currentFolderId || ''
        }),
        signal: controller.signal
      });

      clearTimeout(timeoutId);
      const result = await response.json();
      if (result.success) {
        successCount++;
        // Remove from selected list so user knows it's done
        const idx = selectedLocalFiles.findIndex(f => f.path === file.path);
        if (idx !== -1) selectedLocalFiles.splice(idx, 1);
        updateSelectedLocalFilesUI();
      } else {
        failCount++;
        console.error(`Gagal import ${file.path}:`, result.error);
        showToast('error', `Gagal import ${file.name}: ${result.error}`);
      }
    } catch (error) {
      failCount++;
      const errorMsg = error.name === 'AbortError' ? 'Timeout (File terlalu lama diproses)' : 'Terjadi kesalahan sistem';
      showToast('error', `${file.name}: ${errorMsg}`);
      console.error(`Error import ${file.path}:`, error);
    }
  }

  if (successCount > 0) {
    showToast('success', `${successCount} video berhasil di-import!`);
    if (failCount === 0) closeLocalImportModal();
    
    // Force refresh with a slight delay to ensure DB consistency if needed
    if (window.refreshGalleryData) {
      await window.refreshGalleryData();
      // Second attempt to ensure everything is rendered
      setTimeout(() => window.refreshGalleryData(), 500);
    } else {
      window.location.reload();
    }
  } else {
    showToast('error', 'Semua import gagal. Silakan cek log.');
  }
  
  btn.disabled = false;
  btn.innerHTML = originalHtml;
});

