async function loadBrowserPath(path) {
  currentBrowserPath = path;
  document.getElementById('browserCurrentPath').textContent = path;
  const browserList = document.getElementById('browserList');
  browserList.innerHTML = '<div class="p-4 text-center"><i class="ti ti-loader animate-spin text-primary"></i></div>';
  
  try {
    const res = await fetch(`/api/system/ls?path=${encodeURIComponent(path)}`);
    const data = await res.json();
    
    if (data.success) {
      browserList.innerHTML = '';
      data.files.forEach(file => {
        const item = document.createElement('div');
        item.className = `flex items-center gap-2 p-2 rounded cursor-pointer hover:bg-dark-700 text-xs ${file.isVideo ? 'text-green-400' : 'text-gray-300'}`;
        
        let icon = 'ti-file';
        if (file.isDirectory) icon = 'ti-folder-filled text-yellow-500';
        else if (file.isVideo) icon = 'ti-video';
        
        item.innerHTML = `
          <i class="ti ${icon} shrink-0"></i>
          <span class="truncate">${file.name}</span>
        `;
        
        item.onclick = () => {
          if (file.isDirectory) {
            loadBrowserPath(file.path);
          } else if (file.isVideo) {
            if (!selectedLocalFiles.some(f => f.path === file.path)) {
              selectedLocalFiles.push({
                path: file.path,
                name: file.name
              });
              updateSelectedLocalFilesUI();
              // Add a small visual indicator
              item.classList.add('bg-primary/20');
              setTimeout(() => item.classList.remove('bg-primary/20'), 300);
            }
          }
        };
        browserList.appendChild(item);
      });
      if (data.files.length === 0) {
        browserList.innerHTML = '<div class="p-4 text-center text-gray-500 text-xs">Folder kosong</div>';
      }
    } else {
      browserList.innerHTML = `<div class="p-4 text-center text-red-400 text-xs">${data.error}</div>`;
    }
  } catch (e) {
    browserList.innerHTML = '<div class="p-4 text-center text-red-400 text-xs">Gagal memuat folder</div>';
  }
}

function navigateUp() {
  if (!currentBrowserPath) return;
  
  // Detect if it's a Windows path (e.g., C:\...)
  const isWindows = /^[a-zA-Z]:[\\\/]/.test(currentBrowserPath) || currentBrowserPath.includes('\\');
  const separator = isWindows ? '\\' : '/';
  
  let parts = currentBrowserPath.split(/[\\\/]/).filter(p => p);
  
  // Special case for Windows drive root (e.g. "C:")
  if (isWindows && parts.length <= 1) {
    return; // Already at drive level
  }
  // Special case for Unix root
  if (!isWindows && parts.length === 0) {
    return;
  }

  parts.pop();
  
  let parent = parts.join(separator);
  
  // If we're on Windows and now at drive level, ensure it ends with \
  if (isWindows) {
    if (parent.length === 2 && parent.endsWith(':')) {
      parent += '\\';
    } else if (parent === '') {
      // Should not happen with current logic but as safety
      parent = currentBrowserPath.split(/[\\\/]/)[0] + '\\';
    }
  } else {
    // Unix root
    if (parent === '') parent = '/';
  }
  
  loadBrowserPath(parent);
}


let selectedFiles = [];
const CHUNK_SIZE = 50 * 1024 * 1024;

function isAudioFile(file) {
  const audioTypes = ['audio/mpeg', 'audio/mp3', 'audio/wav', 'audio/x-wav', 'audio/aac', 'audio/mp4', 'audio/x-m4a', 'audio/ogg', 'audio/flac', 'audio/x-flac'];
  const audioExts = ['.mp3', '.wav', '.aac', '.m4a', '.ogg', '.flac'];
  const fileName = file.name.toLowerCase();
  const ext = fileName.substring(fileName.lastIndexOf('.'));
  
  // Check MIME type first
  if (file.type && audioTypes.includes(file.type.toLowerCase())) {
    return true;
  }
  
  // Fallback to extension check
  if (audioExts.includes(ext)) {
    return true;
  }
  
  return false;
}

function isVideoFile(file) {
  const videoTypes = [
    'video/mp4', 'video/avi', 'video/quicktime', 'video/x-msvideo', 'video/x-matroska', 
    'video/webm', 'video/x-flv', 'video/x-ms-wmv', 'video/x-m4v', 'video/3gpp', 
    'video/mp2t', 'video/mpeg'
  ];
  const videoExts = ['.mp4', '.avi', '.mov', '.mkv', '.webm', '.flv', '.wmv', '.m4v', '.3gp', '.ts', '.mpeg', '.mpg'];
  const fileName = file.name.toLowerCase();
  const ext = fileName.substring(fileName.lastIndexOf('.'));
  
  // Check MIME type first
  if (file.type && videoTypes.includes(file.type.toLowerCase())) {
    return true;
  }
  
  // Fallback to extension check
  if (videoExts.includes(ext)) {
    return true;
  }
  
  console.log('Video file check failed for:', file.name, 'Type:', file.type, 'Ext:', ext);
  return false;
}

function isImageFile(file) {
  const imageTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif'];
  const imageExts = ['.jpg', '.jpeg', '.png', '.gif'];
  const fileName = file.name.toLowerCase();
  const ext = fileName.substring(fileName.lastIndexOf('.'));
  
  if (file.type && imageTypes.includes(file.type.toLowerCase())) {
    return true;
  }
  if (imageExts.includes(ext)) {
    return true;
  }
  return false;
}



function getRemainingSpace() {
  if (userDiskLimit > 0) {
    return Math.max(0, userDiskLimit - userDiskUsage);
  }
  return Infinity;
}

function formatFileSize(bytes) {
  if (!bytes || bytes === 0) return '0 B';
  bytes = Number(bytes);
  if (isNaN(bytes)) return '0 B';
  if (bytes < 1024) return bytes + ' B';
  else if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
  else if (bytes < 1073741824) return (bytes / 1048576).toFixed(1) + ' MB';
  else if (bytes < 1099511627776) return (bytes / 1073741824).toFixed(2) + ' GB';
  else return (bytes / 1099511627776).toFixed(2) + ' TB';
}

document.addEventListener('DOMContentLoaded', function() {
  // Check for stored toast messages from previous page load (after upload refresh)
  const successToast = sessionStorage.getItem('upload_success_toast');
  const warningToast = sessionStorage.getItem('upload_warning_toast');
  if (successToast) {
    showToast('success', successToast);
    sessionStorage.removeItem('upload_success_toast');
  } else if (warningToast) {
    showToast('warning', warningToast);
    sessionStorage.removeItem('upload_warning_toast');
  }

  const mediaFileInput = document.getElementById('mediaFileInput');
  const selectedFileInfo = document.getElementById('selectedFileInfo');
  const selectedFileCount = document.getElementById('selectedFileCount');
  const selectedFilesList = document.getElementById('selectedFilesList');
  const clearFileButton = document.getElementById('clearFileButton');
  const uploadDropzone = document.getElementById('uploadDropzone');
  const uploadButton = document.getElementById('uploadButton');
  const uploadProgress = document.getElementById('uploadProgress');
  const uploadProgressBar = document.getElementById('uploadProgressBar');
  const uploadProgressPercent = document.getElementById('uploadProgressPercent');
  const uploadProgressStatus = document.getElementById('uploadProgressStatus');
  const uploadFilesList = document.getElementById('uploadFilesList');
  const searchInput = document.getElementById('searchInput');
  const sortSelect = document.getElementById('sortSelect');

  if (mediaFileInput) {
    mediaFileInput.addEventListener('change', function() {
      const newFiles = Array.from(this.files);
      console.log('Files selected:', newFiles.length, 'Current type:', currentUploadType);
      
      if (newFiles.length > 0) {
        // Log file details for debugging
        newFiles.forEach(f => {
          console.log('File:', f.name, 'Type:', f.type, 'Size:', f.size);
          if (currentUploadType === 'video') {
            console.log('  isVideoFile:', isVideoFile(f));
          } else if (currentUploadType === 'audio') {
            console.log('  isAudioFile:', isAudioFile(f));
          } else {
            console.log('  isImageFile:', isImageFile(f));
          }
        });
        
        // Validate file types based on current upload type
        const invalidFiles = newFiles.filter(f => {
          if (currentUploadType === 'video') {
            return !isVideoFile(f);
          } else if (currentUploadType === 'audio') {
            return !isAudioFile(f);
          } else {
            return !isImageFile(f);
          }
        });
        
        console.log('Invalid files:', invalidFiles.length);
        
        if (invalidFiles.length > 0) {
          const fileTypeMsg = currentUploadType === 'video' 
            ? 'Please select valid video files (MP4, AVI, MOV)' 
            : currentUploadType === 'audio'
              ? 'Please select valid audio files (MP3, WAV, AAC, M4A, OGG, FLAC)'
              : 'Please select valid image files (PNG, JPG, JPEG)';
          showToast('error', fileTypeMsg);
          this.value = '';
          return;
        }
        
        const maxSize = 50 * 1024 * 1024 * 1024;
        const large = newFiles.filter(f => f.size > maxSize);
        if (large.length > 0) {
          showToast('error', `File too large: ${large.map(f => f.name).join(', ')}`);
          this.value = '';
          return;
        }
        
        const totalNewSize = newFiles.reduce((sum, f) => sum + f.size, 0);
        const totalSelectedSize = selectedFiles.reduce((sum, f) => sum + f.size, 0);
        if (userDiskLimit > 0 && (userDiskUsage + totalSelectedSize + totalNewSize) > userDiskLimit) {
          const remaining = getRemainingSpace() - totalSelectedSize;
          showToast('error', `Disk limit exceeded. Remaining space: ${formatFileSize(Math.max(0, remaining))}`);
          this.value = '';
          return;
        }
        
        newFiles.forEach(f => {
          if (!selectedFiles.some(e => e.name === f.name && e.size === f.size)) selectedFiles.push(f);
        });
        updateFilesList();
        uploadDropzone.classList.add('hidden');
        selectedFileInfo.classList.remove('hidden');
        uploadButton.disabled = false;
      }
      this.value = '';
    });
  }

  function updateFilesList() {
    console.log('updateFilesList called, selectedFiles:', selectedFiles.length);
    const totalSize = selectedFiles.reduce((sum, f) => sum + f.size, 0);
    selectedFileCount.textContent = `${selectedFiles.length} file${selectedFiles.length > 1 ? 's' : ''} selected (${formatFileSize(totalSize)})`;
    selectedFilesList.innerHTML = '';
    selectedFiles.forEach((file, i) => {
