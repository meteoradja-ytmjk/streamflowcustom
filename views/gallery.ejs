  }

  if (gridViewBtn && listViewBtn) {
    gridViewBtn.classList.toggle('bg-primary', currentView === 'grid');
    gridViewBtn.classList.toggle('text-white', currentView === 'grid');
    gridViewBtn.classList.toggle('text-gray-400', currentView !== 'grid');
    listViewBtn.classList.toggle('bg-primary', currentView === 'list');
    listViewBtn.classList.toggle('text-white', currentView === 'list');
    listViewBtn.classList.toggle('text-gray-400', currentView !== 'list');
  }
}

