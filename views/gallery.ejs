            <img src="/images/google drive.png" alt="Google Drive" class="w-5 h-5">
            <span>Google Drive</span>
          </button>
          <button onclick="openCloudModal('mediafire')" class="w-full flex items-center gap-3 px-4 py-3 hover:bg-dark-700 transition-colors text-sm text-left">
            <img src="/images/mediafire.png" alt="Mediafire" class="w-5 h-5">
            <span>Mediafire</span>
