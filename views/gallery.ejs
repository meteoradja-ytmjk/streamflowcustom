              <th class="px-4 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">Name</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider w-24">Duration</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider w-28">Size</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider w-32">Modified</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-300 uppercase tracking-wider w-24">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-700">
            <% if (hasRootFolders) { %>
            <% folders.forEach(function(folder) { %>
            <tr class="gallery-list-item folder-drop-target group hover:bg-dark-700 transition-colors cursor-pointer"
              data-folder-id="<%= folder.id %>" data-kind="folder" data-type="folder" data-title="<%= folder.name %>" data-date="<%= folder.updated_at || folder.created_at %>" data-size="0"
              onclick="window.location.href='/gallery?folder=<%= folder.id %>'">
              <td class="px-4 py-3"></td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  <div class="w-12 h-8 rounded bg-primary/15 text-primary flex-shrink-0 relative flex items-center justify-center">
                    <i class="ti ti-folder text-lg"></i>
                  </div>
                  <div class="flex items-center gap-2 min-w-0">
                    <span class="font-medium text-sm truncate max-w-xs"><%= folder.name %></span>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3 text-sm text-gray-500">--</td>
              <td class="px-4 py-3 text-sm text-gray-400"><%= folder.item_count || 0 %> item<%= (folder.item_count || 0) === 1 ? '' : 's' %></td>
              <td class="px-4 py-3 text-sm text-gray-400"><%= new Date(folder.updated_at || folder.created_at).toLocaleDateString() %></td>
              <td class="px-4 py-3 text-right">
                <div class="flex items-center justify-end gap-1">
                  <button class="p-1.5 hover:bg-dark-600 rounded text-gray-400 hover:text-white transition-colors"
                    onclick="event.preventDefault(); event.stopPropagation(); showRenameFolderDialog('<%= folder.id %>', '<%= folder.name %>')">
                    <i class="ti ti-pencil text-sm"></i>
                  </button>
                  <button class="p-1.5 hover:bg-dark-600 rounded text-gray-400 hover:text-red-400 transition-colors"
                    onclick="event.preventDefault(); event.stopPropagation(); showDeleteFolderDialog('<%= folder.id %>', '<%= folder.name %>')">
                    <i class="ti ti-trash text-sm"></i>
                  </button>
                </div>
              </td>
            </tr>
            <% }); %>
            <% } %>
            <% videos.forEach(function(video) { 
              const isAudio = video.filepath && (video.filepath.includes('/audio/') || video.filepath.endsWith('.m4a') || video.filepath.endsWith('.aac') || video.filepath.endsWith('.mp3'));
              const isImage = video.format === 'image' || (video.filepath && (video.filepath.includes('/thumbnails/') || video.filepath.endsWith('.jpg') || video.filepath.endsWith('.jpeg') || video.filepath.endsWith('.png') || video.filepath.endsWith('.gif')));
              const mediaType = isAudio ? 'audio' : isImage ? 'image' : 'video';
              const displayThumbnail = video.thumbnail_path || (isImage ? video.filepath : '/images/default-video-thumbnail.svg');
            %>
            <tr class="gallery-list-item file-item-row <%= isImage ? 'gallery-inspectable' : 'gallery-playable' %> group hover:bg-dark-700 transition-colors cursor-pointer"
              data-id="<%= video.id %>" data-kind="file" data-title="<%= video.title %>" data-date="<%= video.upload_date %>" data-size="<%= video.file_size %>" data-type="<%= mediaType %>"
              data-filepath="<%= video.filepath %>" data-resolution="<%= video.resolution %>"
              draggable="true"
              onclick="<%= isImage ? "openMediaInspector('" + video.id + "', '" + video.title.replace(/'/g, "\\'") + "', '" + video.filepath + "', " + video.file_size + ", '" + (video.resolution || '') + "')" : "playMedia('" + video.id + "', '" + video.title.replace(/'/g, "\\'") + "', '" + mediaType + "')" %>">
              <td class="px-4 py-3" onclick="event.stopPropagation()">
                <input type="checkbox" class="file-checkbox w-4 h-4 rounded border-2 border-gray-600 bg-dark-700 checked:bg-primary checked:border-primary cursor-pointer"
                  data-id="<%= video.id %>"
                  onclick="event.stopPropagation(); toggleFileSelection('<%= video.id %>')"
                  onchange="event.stopPropagation()">
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  <div class="w-12 h-8 rounded overflow-hidden bg-[#181818] flex-shrink-0 relative flex items-center justify-center">
                    <% if (isAudio) { %>
                    <i class="ti ti-music text-primary"></i>
                    <% } else { %>
                    <img src="<%= displayThumbnail %>" alt="" class="w-full h-full object-cover">
                    <% } %>
                  </div>
                  <div class="flex items-center gap-2">
                    <span class="font-medium text-sm truncate max-w-xs"><%= video.title %></span>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3 text-sm text-gray-400"><%= isImage ? '--' : formatDuration(video.duration) %></td>
              <td class="px-4 py-3 text-sm text-gray-400"><%= formatFileSize(video.file_size) %></td>
              <td class="px-4 py-3 text-sm text-gray-400"><%= new Date(video.upload_date).toLocaleDateString() %></td>
              <td class="px-4 py-3 text-right">
                <div class="flex items-center justify-end gap-1">
                  <button class="p-1.5 hover:bg-dark-600 rounded text-gray-400 hover:text-white transition-colors"
                    onclick="event.stopPropagation(); showRenameDialog('<%= video.id %>', '<%= video.title %>')">
                    <i class="ti ti-pencil text-sm"></i>
                  </button>
                  <button class="p-1.5 hover:bg-dark-600 rounded text-gray-400 hover:text-red-400 transition-colors"
                    onclick="event.stopPropagation(); showDeleteDialog('<%= video.id %>', '<%= video.title %>')">
                    <i class="ti ti-trash text-sm"></i>
                  </button>
                </div>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
    <% } else { %>
    <div class="text-center py-12">
      <div class="w-16 h-16 rounded-full bg-dark-700 flex items-center justify-center mx-auto mb-4">
        <i class="ti ti-video text-gray-500 text-2xl"></i>
      </div>
