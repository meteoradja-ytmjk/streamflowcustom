    </div>
  </div>

  <!-- Breadcrumb -->
  <% if (currentFolder) { %>
  <div class="flex items-center gap-2 text-sm text-gray-400 mb-3 mt-4">
    <a href="/gallery" class="hover:text-white transition-colors">Gallery</a>
    <i class="ti ti-chevron-right text-xs"></i>
    <span class="text-white font-medium"><%= currentFolder.name %></span>
  </div>
  <div id="rootDropZone" class="border border-dashed border-gray-600 rounded-lg px-4 py-3 text-sm text-gray-400 bg-dark-800/50">
    Drag file here to move it back to root
  </div>
  <% } %>
</div>

<%
  const hasRootFolders = !currentFolder && folders && folders.length > 0;
  const galleryItemCount = (videos ? videos.length : 0) + (hasRootFolders ? folders.length : 0);
  const hasGalleryItems = galleryItemCount > 0;
%>

<!-- Sub-Tab 1: Media Gallery View (Video & Audio) -->
<div id="subTabMediaGalleryView" class="space-y-6">
<div class="bg-gray-800 rounded-lg shadow-md overflow-hidden">
  <!-- Toolbar -->
  <div class="p-3 sm:p-4 border-b border-gray-700">
    <!-- Search Bar - Full Width -->
    <div class="mb-3">
      <div class="relative w-full">
        <input type="text" id="searchInput" placeholder="Search files and folders..."
