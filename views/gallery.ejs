          <button onclick="openCloudModal('dropbox')" class="w-full flex items-center gap-3 px-4 py-3 hover:bg-dark-700 transition-colors text-sm text-left">
            <img src="/images/dropbox.png" alt="Dropbox" class="w-5 h-5">
            <span>Dropbox</span>
          </button>
          <button onclick="openCloudModal('mega')" class="w-full flex items-center gap-3 px-4 py-3 hover:bg-dark-700 transition-colors text-sm text-left">
            <img src="/images/mega.png" alt="MEGA" class="w-5 h-5">
            <span>MEGA</span>
          </button>
          <button onclick="openLocalImportModal()" class="w-full flex items-center gap-3 px-4 py-3 hover:bg-dark-700 transition-colors border-t border-gray-700 text-sm text-left rounded-b-lg">
            <i class="ti ti-device-floppy text-lg text-primary"></i>
            <span>Local Path</span>
          </button>
