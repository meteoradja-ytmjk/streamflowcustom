<div id="gallery-init-data" class="hidden"
  data-current-folder-id="<%= currentFolderId || '' %>"
  data-videos="<%= JSON.stringify(videos || []) %>"
  data-folders="<%= JSON.stringify(folders || []) %>"
  data-current-folder="<%= JSON.stringify(currentFolder || null) %>"
  data-user-role="<%= typeof user !== 'undefined' ? user.role : 'user' %>">
</div>


<script>
  const initData = document.getElementById('gallery-init-data').dataset;
  let currentView = 'grid';
  let currentUploadType = 'video';
  let userDiskUsage = 0;
  let userDiskLimit = 0;
  const currentFolderId = initData.currentFolderId;
  let galleryVideosState = JSON.parse(initData.videos);
  let galleryFoldersState = JSON.parse(initData.folders);
  let galleryCurrentFolderState = JSON.parse(initData.currentFolder);
  const userRoles = initData.userRole;

// ========================================
// DECLARE ALL WINDOW FUNCTIONS FIRST (CRITICAL FOR ONCLICK)
// ========================================

// Tab switching - MUST BE DEFINED FIRST
window.switchGalleryTab = function(tab) {
  console.log('switchGalleryTab called:', tab);
  const currentGalleryTab = tab;
  const tabMedia = document.getElementById('tabNavMedia');
  const tabThumbnail = document.getElementById('tabNavThumbnail');
  const viewMedia = document.getElementById('subTabMediaGalleryView');
