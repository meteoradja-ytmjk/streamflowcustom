  function escapeHtml(value) {
    return String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function isAudioMediaItem(video) {
    const filepath = (video.filepath || '').toLowerCase();
    return filepath.includes('/audio/') || filepath.endsWith('.m4a') || filepath.endsWith('.aac') || filepath.endsWith('.mp3');
  }

  function isImageMediaItem(video) {
    const filepath = (video.filepath || '').toLowerCase();
    const format = (video.format || '').toLowerCase();
    return format === 'image' || filepath.includes('/thumbnails/') || filepath.endsWith('.jpg') || filepath.endsWith('.jpeg') || filepath.endsWith('.png') || filepath.endsWith('.gif');
  }

  function formatGalleryDate(value) {
    if (!value) return '--';
    return new Date(value).toLocaleDateString();
  }

