          <i class="ti ti-photo"></i>
          <span>Thumbnails</span>
        </button>
      </div>
    </div>
    
    <!-- Action Buttons - Hidden when Thumbnail tab active -->
    <div id="headerActionButtons" class="flex gap-2 w-full lg:w-auto">
