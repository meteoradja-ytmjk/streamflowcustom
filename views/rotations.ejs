    if (fallbackIcon) fallbackIcon.classList.add('hidden');
    document.getElementById('rotationChannelName').textContent = defaultChannel.channel_name;
  } else {
    document.getElementById('rotationChannelId').value = '';
    document.getElementById('rotationChannelThumb').style.display = 'none';
    const fallbackIcon = document.querySelector('#rotationChannelThumbContainer .fallback-icon');
    if (fallbackIcon) fallbackIcon.classList.remove('hidden');
    document.getElementById('rotationChannelName').textContent = 'Select Channel';
