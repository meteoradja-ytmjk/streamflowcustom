  document.getElementById('rotationDurationBadge').textContent = 'Duration: 00:00';
  document.getElementById('globalMonetization').checked = false;
  
  const now = new Date();
  const year = now.getFullYear();
  const month = String(now.getMonth() + 1).padStart(2, '0');
  const day = String(now.getDate()).padStart(2, '0');
  document.getElementById('rotationStartDate').value = `${year}-${month}-${day}`;
  
  document.getElementById('repeatMode').value = 'daily';
  
