        document.getElementById('globalMonetization').checked = rotation.items[0].youtube_monetization === true || rotation.items[0].youtube_monetization === 1;
        
        const globalAlteredVal = rotation.global_youtube_altered_content === true || rotation.global_youtube_altered_content === 1 || String(rotation.global_youtube_altered_content) === 'true';
